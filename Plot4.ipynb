import yfinance as yf
import pandas as pd
import numpy as np
import plotly.graph_objects as go
from pypfopt import EfficientFrontier, risk_models, expected_returns
from datetime import datetime, timedelta

def run_conway_final_challenger():
    print("."*85)
    print("🚀 CONWAY CHALLENGER: INTERACTIVE QUANT SUITE")
    print(f"   Launch Date: {datetime.now().strftime('%Y-%m-%d')}")
    print("."*85)

    # 1. ASSET SELECTION & BENCHMARKS
    tickers = ["NVDA", "AAPL", "MSFT", "AMZN", "META", "TSLA", "GOOGL", "AVGO", "BRK-B", "PLTR",
               "RELIANCE.NS", "HDFCBANK.NS", "TCS.NS", "BHARTIARTL.NS", "ICICIBANK.NS", 
               "SBIN.NS", "INFY.NS", "BAJFINANCE.NS", "HINDUNILVR.NS", "ADANIPORTS.NS"]
    benchmarks = {"S&P 500": "^GSPC", "Nifty 500": "^CRSLDX"}
    
    # 2. DATA INGESTION
    print("[📡] Downloading 2 years of global data...")
    all_symbols = tickers + list(benchmarks.values())
    data = yf.download(all_symbols, period="2y", auto_adjust=True, progress=False)['Close']
    
    # Flatten MultiIndex Columns (The 'KeyError' Fix)
    if isinstance(data.columns, pd.MultiIndex):
        data.columns = [col for col in data.columns]
    
    # 3. OPTIMIZATION (Train on 1st Year)
    train_data = data[tickers].iloc[:252].ffill().dropna()
    mu = expected_returns.mean_historical_return(train_data)
    S = risk_models.CovarianceShrinkage(train_data).ledoit_wolf()
    
    ef = EfficientFrontier(mu, S)
    weights = ef.max_sharpe()
    portfolio_weights = pd.Series(ef.clean_weights())
    
    # 4. BACKTEST (Test on 2nd Year / Out-of-Sample)
    test_data = data.iloc[252:].ffill().dropna()
    daily_rets = test_data[tickers].pct_change().dropna()
    port_rets = (daily_rets * portfolio_weights).sum(axis=1)
    
    # Cumulative Wealth: $10,000 Starting Capital
    wealth_df = pd.DataFrame({"CONWAY_ELITE": (1 + port_rets).cumprod() * 10000})
    
    for name, sym in benchmarks.items():
        bench_rets = test_data[sym].pct_change().dropna()
        wealth_df[name] = (1 + bench_rets).cumprod() * 10000

    # 5. INTERACTIVE VISUALIZATION (Plotly)
    fig = go.Figure()

    # Portfolio Line (Neon Pink)
    fig.add_trace(go.Scatter(x=wealth_df.index, y=wealth_df["CONWAY_ELITE"],
                             mode='lines', name='CONWAY ELITE',
                             line=dict(color='#ff007f', width=4),
                             hovertemplate='<b>%{x}</b><br>Wealth: $%{y:,.2f}<extra></extra>'))

    # S&P 500 Line (Cyan)
    fig.add_trace(go.Scatter(x=wealth_df.index, y=wealth_df["S&P 500"],
                             mode='lines', name='S&P 500 (US)',
                             line=dict(color='#00f2ff', width=2, dash='dot')))

    # Nifty 500 Line (Saffron)
    fig.add_trace(go.Scatter(x=wealth_df.index, y=wealth_df["Nifty 500"],
                             mode='lines', name='Nifty 500 (India)',
                             line=dict(color='#ff9933', width=2, dash='dash')))

    # Professional Dashboard Layout
    fig.update_layout(
        template='plotly_dark',
        title=dict(text='THE SHOWDOWN: GLOBAL CHALLENGE 2026', x=0.5, font=dict(size=22)),
        paper_bgcolor='#0b0d0f',
        plot_bgcolor='#0b0d0f',
        hovermode='x unified',
        xaxis=dict(showgrid=False, title='Trading Session Timeline'),
        yaxis=dict(gridcolor='#1e2124', title='Investment Value ($)', side='right'),
        legend=dict(yanchor="top", y=0.99, xanchor="left", x=0.01, bgcolor="rgba(0,0,0,0)")
    )

    fig.show()

    # 6. PERFORMANCE SCORECARD
    final_rets = ((wealth_df.iloc[-1] / 10000) - 1) * 100
    print("\n" + "`"*85)
    print(f"📊 12-MONTH QUANTITATIVE SCORECARD")
    print("`"*85)
    for name, ret in final_rets.items():
        print(f"* {name:15} : {ret:6.2f}% Cumulative Return")
    
    alpha = final_rets["CONWAY_ELITE"] - final_rets["Nifty 500"]
    print(f"\n💡 STRATEGY ALPHA: {alpha:.2f}% against Nifty 500")
    print("`"*85)

if __name__ == "__main__":
    run_conway_final_challenger()
