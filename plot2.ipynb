import yfinance as yf
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pypfopt import EfficientFrontier, risk_models, expected_returns, plotting
from pypfopt.discrete_allocation import DiscreteAllocation, get_latest_prices
from datetime import datetime

def run_global_elite_optimizer():
    # 1. THE 20-STOCK UNIVERSE (10 US | 10 Indian)
    us_stocks = ["NVDA", "AAPL", "MSFT", "AMZN", "META", "TSLA", "GOOGL", "AVGO", "BRK-B", "PLTR"]
    in_stocks = ["RELIANCE.NS", "HDFCBANK.NS", "TCS.NS", "BHARTIARTL.NS", "ICICIBANK.NS", 
                 "SBIN.NS", "INFY.NS", "BAJFINANCE.NS", "HINDUNILVR.NS", "ADANIPORTS.NS"]
    
    all_tickers = us_stocks + in_stocks
    print(f"🔄 Analysis Start: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"[📡] Downloading 20 global assets...")

    # FETCH & CLEAN (Fixing MultiIndex/NaN issues)
    df_raw = yf.download(all_tickers, period="3y", interval="1d", progress=False, auto_adjust=True)
    prices = df_raw['Close'].ffill().dropna()
    prices.columns = [col for col in prices.columns] # Flattening headers

    # 2. STATISTICAL MODELING
    mu = expected_returns.mean_historical_return(prices)
    S = risk_models.CovarianceShrinkage(prices).ledoit_wolf()

    # 3. COLOR-CODED VISUALIZATION
    ef_plot = EfficientFrontier(mu, S)
    fig, ax = plt.subplots(figsize=(14, 8), facecolor='#0b0d0f')
    ax.set_facecolor('#0b0d0f')
    
    # Define Neon Market Colors
    color_map = {t: "#00f2ff" for t in us_stocks} # Neon Blue (US)
    color_map.update({t: "#ff9933" for t in in_stocks}) # Saffron (India)
    
    # Plot Efficient Frontier Curve
    plotting.plot_efficient_frontier(ef_plot, ax=ax, show_assets=False)
    
    # Manual Scatter for Beauty & Market Identification
    asset_sigmas = np.sqrt(np.diag(S))
    for i, ticker in enumerate(mu.index):
        ax.scatter(asset_sigmas[i], mu[i], s=100, c=color_map[ticker], 
                   edgecolor='white', linewidth=0.5, alpha=0.9, label=ticker if i < 1 else "")
        ax.annotate(ticker, (asset_sigmas[i], mu[i]), xytext=(5, 5), 
                    textcoords='offset points', fontsize=9, color='white', alpha=0.7)

    # 4. FIND THE "MAX SHARPE" (Optimal Portfolio)
    ef = EfficientFrontier(mu, S)
    weights = ef.max_sharpe()
    ret_t, std_t, _ = ef.portfolio_performance(verbose=True)
    
    ax.scatter(std_t, ret_t, marker="*", s=400, c="#ff007f", label="Optimal (Max Sharpe)")

    # Formatting "Beautiful" Labels
    ax.set_title(f"GLOBAL EFFICIENT FRONTIER: US ({us_stocks[0]}...) vs INDIA ({in_stocks[0]}...)", 
                 color='white', fontsize=16, fontweight='bold', pad=20)
    ax.set_xlabel("Volatility (Risk)", color='white'); ax.set_ylabel("Expected Return", color='white')
    ax.tick_params(colors='white')
    ax.grid(color='#1e2124', linestyle='--')
    
    # Legend for Markets
    from matplotlib.lines import Line2D
    legend_elements = [Line2D([0], [0], marker='o', color='w', label='US Stocks', markerfacecolor='#00f2ff', markersize=10),
                       Line2D([0], [0], marker='o', color='w', label='Indian Stocks', markerfacecolor='#ff9933', markersize=10),
                       Line2D([0], [0], marker='*', color='w', label='Optimal Portfolio', markerfacecolor='#ff007f', markersize=15)]
    ax.legend(handles=legend_elements, facecolor='#1e2124', edgecolor='none', labelcolor='white')
    
    plt.tight_layout(); plt.show()

    # 5. FINAL REPORT
    print("\n" + "="*85)
    print("📈 FINAL CONWAY REPORT: TARGET ALLOCATIONS")
    print("="*85)
    cleaned_weights = ef.clean_weights()
    for t, w in cleaned_weights.items():
        if w > 0:
            market = "US" if t in us_stocks else "INDIA"
            print(f"* [{market}] {t:15} : {w*100:6.2f}%")
    print("."*85)

if __name__ == "__main__":
    run_global_elite_optimizer()
