import yfinance as yf
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pypfopt import EfficientFrontier, risk_models, expected_returns, plotting
from pypfopt.discrete_allocation import DiscreteAllocation, get_latest_prices
from datetime import datetime
import copy

def run_portfolio_optimizer():
    print("="*80)
    print("💼 CONWAYS CONSULTANCY: STRATEGIC PORTFOLIO OPTIMIZER")
    print(f"   Analysis Date: {datetime.now().strftime('%Y-%m-%d')}")
    print("="*80)

    # 1. LIVE DATA: Multi-Index Flattening logic
    tickers = ["AAPL", "MSFT", "NVDA", "RELIANCE.NS", "BEL.NS", "TSLA", "GOOGL"]
    print(f"[📡] Downloading data for: {', '.join(tickers)}")
    
    # Force auto_adjust to ensure we get a clean Close column
    df = yf.download(tickers, period="3y", interval="1d", progress=False, auto_adjust=True)
    
    # Flatten MultiIndex to standard column names (Crucial for 2026)
    if isinstance(df.columns, pd.MultiIndex):
        df = df['Close'] # Select only Close prices
        if isinstance(df.columns, pd.MultiIndex):
            df.columns = [col[0] for col in df.columns.values]
    
    # 2. CALCULATE RETURNS & RISK
    mu = expected_returns.mean_historical_return(df)
    S = risk_models.CovarianceShrinkage(df).ledoit_wolf()

    # 3. EFFICIENT FRONTIER PLOTTING (The "Safety" Fix)
    # We instantiate a temporary object for plotting only
    ef_plot = EfficientFrontier(mu, S)
    fig, ax = plt.subplots(figsize=(10, 6))
    plotting.plot_efficient_frontier(ef_plot, ax=ax, show_assets=True)
    
    # 4. ACTUAL OPTIMIZATION (Instantiating a fresh object)
    ef = EfficientFrontier(mu, S)
    weights = ef.max_sharpe() # No InstantiationError here
    cleaned_weights = ef.clean_weights()
    
    # Overlay the Max Sharpe point on the graph
    ret_tangent, std_tangent, _ = ef.portfolio_performance(verbose=True)
    ax.scatter(std_tangent, ret_tangent, marker="*", s=200, c="r", label="Max Sharpe")
    
    plt.title("2026 Strategic Efficient Frontier")
    plt.legend()
    plt.show()

    # 5. DISCRETE ALLOCATION
    print("\n" + "="*80)
    print("📊 OPTIMAL PORTFOLIO WEIGHTS")
    print("="*80)
    
    portfolio_val = 10000 # Example USD/INR value
    latest_prices = get_latest_prices(df)
    da = DiscreteAllocation(cleaned_weights, latest_prices, total_portfolio_value=portfolio_val)
    allocation, leftover = da.lp_portfolio()

    for t, w in cleaned_weights.items():
        if w > 0: print(f"* {t}: {w*100:.2f}% allocation")

    print("\n💰 SPECIFIC BUY ORDERS:")
    for t, s in allocation.items(): print(f"  - Buy {s} shares of {t}")
    print(f"\nRemaining Cash: {leftover:.2f}")

if __name__ == "__main__":
    run_portfolio_optimizer()
