import yfinance as yf
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pypfopt import (EfficientFrontier, risk_models, expected_returns, 
                     plotting, BlackLittermanModel, objective_functions)
from datetime import datetime
from matplotlib.lines import Line2D

def run_conway_ultra_optimizer():
    # 1. ASSET DEFINITION
    us_stocks = ["NVDA", "AAPL", "MSFT", "AMZN", "META", "TSLA", "GOOGL", "AVGO", "BRK-B", "PLTR"]
    in_stocks = ["RELIANCE.NS", "HDFCBANK.NS", "TCS.NS", "BHARTIARTL.NS", "ICICIBANK.NS", 
                 "SBIN.NS", "INFY.NS", "BAJFINANCE.NS", "HINDUNILVR.NS", "ADANIPORTS.NS"]
    all_tickers = us_stocks + in_stocks
    
    print(f"🚀 Initializing ConWay Ultra Engine | {datetime.now().strftime('%H:%M:%S')}")

    # 2. DATA INGESTION & CLEANING
    df_raw = yf.download(all_tickers, period="3y", interval="1d", progress=False, auto_adjust=True)
    prices = df_raw['Close'].ffill().dropna()
    prices.columns = [col for col in prices.columns] 

    # 3. BLACK-LITTERMAN INTEGRATION (Expert Views)
    # We inject views based on the Feb 2026 Trade Deal
    viewdict = {
        "NVDA": 0.25,      # View: AI demand remains exponential
        "RELIANCE.NS": 0.18, # View: Trade deal lowers export costs
        "ADANIPORTS.NS": 0.15 # View: Logistics boom in India
    }
    
    # Calculate Market Caps for BL Weighting
    mcaps = {t: yf.Ticker(t).info.get('marketCap', 1e11) for t in all_tickers}
    S = risk_models.CovarianceShrinkage(prices).ledoit_wolf()
    
    bl = BlackLittermanModel(S, absolute_views=viewdict, market_caps=mcaps)
    rets = bl.bl_returns() # Refined returns using BL math

    # 4. MONTE CARLO SIMULATION (Robustness Check)
    print("[🎲] Running 5,000 Monte Carlo Portfolios...")
    mc_rets, mc_vols = [], []
    for _ in range(5000):
        w = np.random.random(len(all_tickers))
        w /= np.sum(w)
        mc_rets.append(np.sum(rets * w) * 252)
        mc_vols.append(np.sqrt(np.dot(w.T, np.dot(S * 252, w))))

    # 5. OPTIMIZATION WITH CVAR & TRANSACTION COSTS
    ef = EfficientFrontier(rets, S)
    # Feature: Add Transaction Cost Penalty (L1 Regularization)
    ef.add_objective(objective_functions.L2_reg, gamma=0.1) 
    # Feature: Weight Constraints (No single stock > 15% for safety)
    ef.add_constraint(lambda w: w <= 0.15)
    
    weights = ef.max_sharpe()
    ret_opt, vol_opt, _ = ef.portfolio_performance()

    # 6. BEAUTIFUL VISUALIZATION
    fig, ax = plt.subplots(figsize=(14, 9), facecolor='#0b0d0f')
    ax.set_facecolor('#0b0d0f')
    
    # Plot Monte Carlo Cloud
    ax.scatter(mc_vols, mc_rets, c=np.array(mc_rets)/np.array(mc_vols), 
               marker='o', s=10, cmap='viridis', alpha=0.3, label="Monte Carlo Scenarios")
    
    # Plot Individual Assets
    color_map = {t: "#00f2ff" for t in us_stocks}
    color_map.update({t: "#ff9933" for t in in_stocks})
    
    asset_vols = np.sqrt(np.diag(S)) * np.sqrt(252)
    asset_rets = rets * 252
    
    for i, t in enumerate(rets.index):
        ax.scatter(asset_vols[i], asset_rets[i], s=120, c=color_map[t], edgecolors='white', zorder=5)
        ax.annotate(t, (asset_vols[i], asset_rets[i]), color='white', fontsize=8, xytext=(5,5), textcoords='offset points')

    # Plot Optimal Point
    ax.scatter(vol_opt, ret_opt, marker="*", s=500, c="#ff007f", label="CONWAY OPTIMAL", zorder=10)

    # Styling
    ax.set_title("CONWAY ULTRA: US-INDIA PORTFOLIO OPTIMIZATION (2026)", color='white', fontsize=18, pad=20)
    ax.set_xlabel("Annualized Risk (Volatility)", color='white'); ax.set_ylabel("Annualized Return", color='white')
    ax.grid(color='#1e2124', linestyle='--', alpha=0.5)
    ax.tick_params(colors='white')
    
    legend_elements = [
        Line2D([0], [0], marker='o', color='w', label='US Blue-Chips', markerfacecolor='#00f2ff', markersize=10),
        Line2D([0], [0], marker='o', color='w', label='Indian Giants', markerfacecolor='#ff9933', markersize=10),
        Line2D([0], [0], marker='*', color='w', label='ConWay Optimal', markerfacecolor='#ff007f', markersize=18)
    ]
    ax.legend(handles=legend_elements, facecolor='#1e2124', labelcolor='white', frameon=False)
    plt.show()

    # 7. FINAL QUANT REPORT
    print_ultra_report(ef.clean_weights(), us_stocks, in_stocks)

def print_ultra_report(weights, us, ind):
    print("\n" + "="*85)
    print("📈 CONWAY ULTRA QUANTITATIVE ALLOCATION REPORT")
    print("."*85)
    for t, w in weights.items():
        if w > 0.01: # Only show allocations > 1%
            region = "US" if t in us else "INDIA"
            print(f"* [{region}] {t:15} : {w*100:6.2f}% weight")
    print("\n💡 STRATEGY: This portfolio maximizes the Sharpe Ratio while penalizing")
    print("unnecessary turnover and capping concentration risk at 15% per asset.")
    print("."*85)

if __name__ == "__main__":
    run_conway_ultra_optimizer()
